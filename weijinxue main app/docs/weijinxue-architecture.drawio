                </mxCell>
                <mxCell id="g4" value="4. localStorage ↔ Firestore sync" style="swimlane;startSize=36;fillColor=#e1d5e7;strokeColor=#9673a6;html=1;fontColor=#1a1a1a;" parent="b1" vertex="1">
