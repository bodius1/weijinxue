                </mxCell>
                <mxCell id="g1n" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Symptom&lt;/b&gt;: syllable won&amp;#39;t advance / stuck on wrong tone&lt;br&gt;&lt;b&gt;Files&lt;/b&gt;: TypeTab, usePinyinStream, pinyinSyllables, pinyinIme&lt;br&gt;&lt;b&gt;Flow&lt;/b&gt;: keystroke → stripTones → getMatchStatus → cell state&lt;br&gt;&lt;b&gt;State&lt;/b&gt;: React buffer + charStates (session)&lt;br&gt;&lt;b&gt;Root&lt;/b&gt;: tone strip ü/lv mismatch; syllable split vs JSON py&lt;br&gt;&lt;b&gt;Tests&lt;/b&gt;: manual Type sentence stream; no dedicated unit test&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#ffffff;strokeColor=#6c8ebf;spacingLeft=10;fontColor=#1a1a1a;fontSize=14;" parent="g1" vertex="1">
                    <mxGeometry x="12" y="36" width="476" height="120" as="geometry"/>
