                <mxCell id="g1" value="&lt;font style=&quot;font-size:18px&quot;&gt;1. Type pinyin recognition&lt;/font&gt;" style="swimlane;startSize=36;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;fontColor=#1a1a1a;" parent="b1" vertex="1">
