                </mxCell>
                <mxCell id="g2" value="2. Sentence IME ranking" style="swimlane;startSize=36;fillColor=#d5e8d4;strokeColor=#82b366;html=1;fontColor=#1a1a1a;" parent="b1" vertex="1">
                    <mxGeometry x="560" y="80" width="500" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="g2n" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Symptom&lt;/b&gt;: wrong hanzi #1; long phrase leaks; 请 alone fails&lt;br&gt;&lt;b&gt;Files&lt;/b&gt;: sentenceIme.js, TypeTab (candidates useMemo), pinyinIme&lt;br&gt;&lt;b&gt;Flow&lt;/b&gt;: imeInput → mergeSentenceContextCandidates → trySelectSlot&lt;br&gt;&lt;b&gt;State&lt;/b&gt;: sentLines[0], committedPos, candidatesRef&lt;br&gt;&lt;b&gt;Root&lt;/b&gt;: classifySentenceSpanMatch; isGlobalSentenceFallbackCompatible&lt;br&gt;&lt;b&gt;Tests&lt;/b&gt;: sentenceIme.js comment checklist; scripts/test-yuban-ime*.mjs (Yuban rank)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#ffffff;strokeColor=#82b366;spacingLeft=10;fontColor=#1a1a1a;fontSize=14;" parent="g2" vertex="1">
