            <root>
                <mxCell id="b0"/>
                <mxCell id="b1" parent="b0"/>
                <mxCell id="b-legend" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;Bug Impact Map&lt;/b&gt; — symptom → files → state → root cause → tests&lt;br&gt;Flow: UI (blue) → Logic (green) → Data (yellow) → State (purple)&lt;/font&gt;" style="text;html=1;align=left;fillColor=#ffffff;strokeColor=#999999;rounded=1;spacing=8;fontColor=#1a1a1a;fontSize=15;" parent="b1" vertex="1">
