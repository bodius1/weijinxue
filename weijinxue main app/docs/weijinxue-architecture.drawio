                    <mxGeometry x="1080" y="80" width="500" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="g3n" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Symptom&lt;/b&gt;: missing lines; bad py alignment; filter drops all rows&lt;br&gt;&lt;b&gt;Files&lt;/b&gt;: sentences_hsk*.json, sentenceData.js, hskSentenceFilter, scripts/build-*&lt;br&gt;&lt;b&gt;Flow&lt;/b&gt;: preload → SENT_ROWS_BY_LEVEL → filterRowsByHskVocabulary → deck&lt;br&gt;&lt;b&gt;State&lt;/b&gt;: bundled JSON; sentenceSeenLog (local)&lt;br&gt;&lt;b&gt;Root&lt;/b&gt;: py/cell mismatch; HSK5–6 mirror HSK4 pool&lt;br&gt;&lt;b&gt;Tests&lt;/b&gt;: gen:sentences-hsk* scripts; diagnose:meanings&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#ffffff;strokeColor=#d6b656;spacingLeft=10;fontColor=#1a1a1a;fontSize=14;" parent="g3" vertex="1">
