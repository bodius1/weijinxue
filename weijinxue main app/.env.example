# Weijinxue — copy to .env for local dev (never commit .env)
#
# SAFE in frontend (Vite embeds these in the client bundle; Firebase keys are not secret):
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional app behavior (no provider secrets):
# VITE_YUBAN_STORY_GENERATION_MODE=hybrid

# NEVER put LLM provider keys here — users supply BYOK in the browser (localStorage):
# VITE_ANTHROPIC_API_KEY=
# VITE_GROQ_API_KEY=
# VITE_OPENAI_API_KEY=
